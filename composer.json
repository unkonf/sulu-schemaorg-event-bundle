{
  "name": "unkonf/sulu-schemaorg-event-bundle",
  "type": "sulu-bundle",
  "description": "Sulu bundle for rendering schema.org event information",
  "minimum-stability": "stable",
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "phpstan/extension-installer": true,
      "php-http/discovery": true
    }
  },
  "license": "MIT",
  "authors": [
    {
      "name": "Stephan Hochdörfer",
      "email": "S.Hochdoerfer@bitExpert.de",
      "homepage": "http://www.bitExpert.de"
    }
  ],
  "autoload": {
    "psr-4": {
      "UnKonf\\Sulu\\SchemaOrgEventBundle\\": ""
    }
  },
  "autoload-dev": {
    "psr-4": {
      "UnKonf\\Sulu\\SchemaOrgEventBundle\\Tests\\": "Tests"
    }
  },
  "require": {
    "php": "^8.4",
    "sulu/sulu": "^3.0",
    "symfony/dependency-injection": "^7.4",
    "symfony/framework-bundle": "^7.4",
    "symfony/http-foundation": "^7.4",
    "symfony/http-kernel": "^7.4",
    "symfony/routing": "^7.4"
  },
  "require-dev": {
    "jackalope/jackalope": "^2.0",
    "jackalope/jackalope-doctrine-dbal": "^2.0",
    "madewithlove/license-checker": "^3.0",
    "phly/keep-a-changelog": "^2.12",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-phpunit": "^2.0",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpunit/phpunit": "^11.2",
    "roave/security-advisories": "dev-latest",
    "squizlabs/php_codesniffer": "^3.13"
  },
  "scripts": {
    "check": [
      "@cs-check",
      "@test"
    ],
    "cs-check": "vendor/bin/phpcs",
    "cs-fix": "vendor/bin/phpcbf",
    "check-license": "vendor/bin/license-checker check",
    "analyze": "vendor/bin/phpstan analyze",
    "test": "vendor/bin/phpunit",
    "coverage": "vendor/bin/phpunit --coverage-clover clover.xml"
  }
}
